APP_NAME=VFF
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Europe/Paris

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de données — PostgreSQL 18 + PostGIS 3.6 (conteneur Docker exposé sur 127.0.0.1:5432)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=vff
DB_USERNAME=vff
DB_PASSWORD=vff

# Cache & file d'attente — Valkey (fork BSD de Redis, conteneur `valkey` parle le protocole RESP)
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Bien que les clés soient nommées REDIS_*, le conteneur cible est Valkey (fork BSD compatible RESP)
# Client recommandé : phpredis (extension PHP native) ; fallback predis (composer require predis/predis)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail (dev) — pointer vers Mailpit ou Mailhog si on en ajoute un
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@vff.local"
MAIL_FROM_NAME="${APP_NAME}"

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173

# Cartographie
VITE_MAP_TILES_PROVIDER=maptiler          # maptiler | stadia | osm-raw
VITE_MAPTILER_KEY=                        # clé API MapTiler (free tier sur maptiler.com)
VITE_STADIA_KEY=                          # alternative à MapTiler

# Import OSM
OSM_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OSM_USER_AGENT="VFF-Bot/1.0 (+https://vff-project.org)"

# Ports exposés (Docker → hôte). Override possible.
DB_PORT=5432
VALKEY_PORT=6379
ADMINER_PORT=8080
